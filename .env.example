# Backend API
VITE_API_URL=http://localhost:5000

# Google Looker Studio Dashboard
VITE_LOOKER_DASHBOARD_ID=your_dashboard_id_here
VITE_LOOKER_PAGE_ID=your_page_id_here

# Firebase Configuration (Optional untuk Partner Portal)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Google Sheets API (Opsional untuk integrasi data petani)
VITE_SHEETS_API_KEY=your_google_sheets_api_key
VITE_SHEET_ID=your_sheet_id

# Google Analytics
VITE_GA_ID=your_google_analytics_id

# Stripe (Opsional untuk pembayaran)
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key

# Email Configuration
VITE_CONTACT_EMAIL=partnerships@the-quail-experience.com

# App Settings
VITE_APP_NAME=The Quail Experience
VITE_APP_ENVIRONMENT=development
VITE_DEBUG_MODE=true
